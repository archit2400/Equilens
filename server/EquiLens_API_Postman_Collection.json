      "item": [
        {
          "name": "Analyze Company / Stock",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{clerk_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"AAPL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/analyze",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "analyze"
              ]
            },
            "description": "Performs financial analysis on a target stock symbol or query, fetching live FMP/Yahoo details and scanning Tavily updates before querying Gemini."
          },
          "response": []
        }
      ]
