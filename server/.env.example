PORT=5000
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
# MUST be at least 64 random hex characters — never use a short/guessable string
JWT_SECRET=replace_with_64_byte_random_hex_string

# ── Clerk (SERVER ONLY) ───────────────────────────────────────────────────────
# ⚠️  NEVER put CLERK_SECRET_KEY in client/.env or any frontend file
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your production frontend domain — no trailing slash
ALLOWED_ORIGIN=https://your-app.vercel.app

# ── External APIs ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
FMP_API_KEY=your_fmp_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
